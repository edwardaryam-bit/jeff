{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin",
      "dest": "server.js"
    },
    {
      "src": "/pickups",
      "dest": "server.js"
    },
    {
      "src": "/driver",
      "dest": "server.js"
    },
    {
      "src": "/(.*\\.(html|css|js|png|webp|jpg|jpeg|gif|svg|ico))",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
